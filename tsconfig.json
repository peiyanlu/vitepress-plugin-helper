{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "removeComments": false,
    "emitDeclarationOnly": false,
    "stripInternal": false,
    "types": ["node"]
  },
  "include": ["src"]
}
